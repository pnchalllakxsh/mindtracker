# ──────────────────────────────────────────────────────────────────────────────
# MindTrack – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (required)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/mindtrack?retryWrites=true&w=majority

# JWT signing secret — use a strong random string (≥ 32 chars recommended)
JWT_SECRET=change-me-to-a-long-random-secret

# AI Coach – Generic OpenAI-compatible endpoint
# Point this at any LLM provider (Groq, OpenAI, Ollama, etc.)
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=your-api-key-here
